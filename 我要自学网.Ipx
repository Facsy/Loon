[MITM]
hostname = webapi.51zxw.net

[Script]

# 开屏广告
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/QueryFirstTimeEnterAdConfig$ requires-body=true,timeout=10,script-path=https://github.com/Facsy/Loon/raw/refs/heads/main/51zxw_noad.js,tag=51ZXW Splash

# 首页弹窗
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/HomePageModalType$ requires-body=true,timeout=10,script-path=https://github.com/Facsy/Loon/raw/refs/heads/main/51zxw_noad.js,tag=51ZXW HomeModal

# 金币/会员促销
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/VCoinDiscountPromotion$ requires-body=true,timeout=10,script-path=https://github.com/Facsy/Loon/raw/refs/heads/main/51zxw_noad.js,tag=51ZXW Promotion

# 全局配置
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/AppGlobalConfig$ requires-body=true,timeout=10,script-path=https://github.com/Facsy/Loon/raw/refs/heads/main/51zxw_noad.js,tag=51ZXW GlobalConfig

[Rule]

# 保留为空，后续如需拦截图片 CDN、统计接口等，可按实际情况添加。

[General]

# 保留默认配置
