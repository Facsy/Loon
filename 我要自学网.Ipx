#!name=51自学网 去广告（增强版）
#!desc=屏蔽开屏广告、首页弹窗、运营活动（开发草案）
#!author=ChatGPT
#!version=0.1.0
#!system=ios
#!homepage=https://www.51zxw.net
#!icon=https://raw.githubusercontent.com/Facsy/Loon/refs/heads/main/icon/我要自学网.png

[MITM]
hostname = webapi.51zxw.net

[Script]

# 开屏广告
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/QueryFirstTimeEnterAdConfig$ \
requires-body=true, \
script-path=https://example.invalid/51zxw/51zxw_noad.js, \
tag=51ZXW Splash AD

# 首页弹窗
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/HomePageModalType$ \
requires-body=true, \
script-path=https://example.invalid/51zxw/51zxw_noad.js, \
tag=51ZXW Home Modal

# 金币/会员促销
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/VCoinDiscountPromotion$ \
requires-body=true, \
script-path=https://example.invalid/51zxw/51zxw_noad.js, \
tag=51ZXW Promotion

# 全局配置
http-response ^https:\/\/webapi\.51zxw\.net\/Other\/AppGlobalConfig$ \
requires-body=true, \
script-path=https://example.invalid/51zxw/51zxw_noad.js, \
tag=51ZXW Global Config
